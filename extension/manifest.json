{
  "manifest_version": 3,
  "name": "Austin Trail Conditions Scraper",
  "version": "1.0.0",
  "description": "Scrape Facebook group posts and send to Austin Trail Conditions",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/groups/325119181430845*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
