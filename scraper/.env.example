# Austin Trail Conditions - Facebook Scraper Config
# Copy this to .env and fill in values

# Your deployed site URL
API_URL=https://austintrailconditions.com

# Must match CRON_SECRET on the server
API_SECRET=

# Resend API key for email notifications (same as your server)
RESEND_API_KEY=

# Email to receive scraper run summaries
ALERT_EMAIL=

# From address for emails (optional, defaults to info@austintrailconditions.com)
# FROM_EMAIL=info@austintrailconditions.com

# Max scroll attempts before giving up (safety cap). Default: 50
# Scraper stops early once it finds posts it's already seen.
# MAX_SCROLLS=50

# Set to "false" to see the browser window (useful for debugging/first run)
# HEADLESS=false

# Chrome user data directory (auto-detected, only set if non-standard)
# Default on Linux: ~/.config/google-chrome
# CHROME_PROFILE=/home/youruser/.config/google-chrome
