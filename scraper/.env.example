# Austin Trail Conditions - Facebook Scraper Config
# Copy this to .env and fill in values

# Your deployed site URL
API_URL=https://austintrailconditions.com

# Must match CRON_SECRET on the server
API_SECRET=

# Number of scroll actions (more = more posts, but slower). Default: 8
# SCROLL_COUNT=8

# Set to "false" to see the browser window (useful for debugging/first run)
# HEADLESS=false

# Chrome user data directory (auto-detected, only set if non-standard)
# Default on Linux: ~/.config/google-chrome
# CHROME_PROFILE=/home/youruser/.config/google-chrome
