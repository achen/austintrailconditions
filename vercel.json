{
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/weather",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/facebook",
      "schedule": "0 12,14,16,18,20,22,0,2 * * *"
    },
    {
      "path": "/api/cron/predict",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/scrape",
      "schedule": "*/30 * * * *"
    }
  ]
}
